{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run QEMU",
			"type": "shell",
			"command": "cargo run",
			"isBackground": true,
			"dependsOn": ["Build & Flash Kernel"],
			"problemMatcher": {
                "pattern": { "regexp": "." },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "."
                }
            }
		},
		{
			"label": "Build & Flash Kernel",
			"type": "shell",
			"command": "cargo build && qemu-img create -f raw disk.img 1G && mkfs.vfat -F 32 disk.img && mcopy -i disk.img target/riscv64gc-unknown-none-elf/debug/LicheeRV-Nano-Kernel ::"
		},
		{
			"label": "Test Machine",
			"dependsOn":["Build & Flash Kernel", "Run QEMU"],
			"dependsOrder": "sequence"
		}
	]
}