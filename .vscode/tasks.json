{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run QEMU",
			"type": "shell",
			"command": "cargo run",
			"isBackground": true,
			"dependsOn": ["Build & Flash Kernel"],
			"problemMatcher": {
                "pattern": { "regexp": "." },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "."
                }
            }
		},
		{
			"label": "Create Image",
			"type": "shell",
			"command": "./create-image.sh"
		},
		{
			"label": "Test Machine",
			"dependsOn":["Build & Flash Kernel", "Run QEMU"],
			"dependsOrder": "sequence"
		}
	]
}